{
  "name": "dependabot-pull-request-action",
  "version": "3.0.0",
  "description": "Parse Dependabot commit metadata to automate PR handling",
  "main": "dist/index.js",
  "scripts": {
    "build": "esbuild src/main.ts --bundle --platform=node --target=node24 --outfile=dist/index.js --format=cjs --legal-comments=none",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts",
    "test": "jest",
    "dry-run": "esbuild src/dry-run.ts --bundle --platform=node --target=node24 --format=cjs --outfile=dist/dry-run.js --log-level=warning && node dist/dry-run.js"
  },
  "keywords": [
    "actions",
    "dependabot",
    "merge",
    "approve"
  ],
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=10.0.0"
  },
  "author": "dependabot",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/github": "^9.0.0",
    "@octokit/request-error": "^7.1.0",
    "pluralize": "^8.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "@types/pluralize": "^0.0.33",
    "@types/yargs": "^17.0.33",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.32.1",
    "dotenv": "^17.4.0",
    "esbuild": "^0.27.4",
    "eslint": "^10.1.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-promise": "^7.2.1",
    "globals": "^17.4.0",
    "jest": "^30.3.0",
    "nock": "^14.0.11",
    "ts-jest": "^29.4.9",
    "typescript": "^6.0.2",
    "yaml": "^2.8.3",
    "yargs": "^18.0.0"
  }
}
