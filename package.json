{
  "name": "dependabot-pull-request-action",
  "version": "3.1.0",
  "description": "Parse Dependabot commit metadata to automate PR handling",
  "main": "dist/index.js",
  "scripts": {
    "build": "esbuild src/main.ts --bundle --platform=node --target=node24 --outfile=dist/index.js --format=cjs --legal-comments=none",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts",
    "test": "jest",
    "dry-run": "esbuild src/dry-run.ts --bundle --platform=node --target=node24 --format=cjs --outfile=dist/dry-run.js --log-level=warning && node dist/dry-run.js"
  },
  "keywords": [
    "actions",
    "dependabot",
    "merge",
    "approve"
  ],
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=10.0.0"
  },
  "author": "dependabot",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/github": "^9.1.0",
    "@octokit/request-error": "^7.1.0",
    "pluralize": "^8.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.26.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^24.0.0",
    "@types/pluralize": "^0.0.33",
    "@types/yargs": "^17.0.33",
    "@typescript-eslint/eslint-plugin": "^8.32.1",
    "@typescript-eslint/parser": "^8.32.1",
    "dotenv": "^16.5.0",
    "esbuild": "^0.28.0",
    "eslint": "^9.26.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-promise": "^7.2.1",
    "globals": "^17.5.0",
    "jest": "^29.7.0",
    "nock": "^14.0.4",
    "ts-jest": "^29.3.3",
    "typescript": "^5.8.3",
    "yaml": "^2.7.1",
    "yargs": "^17.7.2"
  }
}
